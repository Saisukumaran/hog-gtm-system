    {
      "parameters": {
        "jsCode": "const seen = new Set();\nconst out = [];\n\nfor (const item of $input.all()) {\n  const url = (item.json['LinkedIn URL'] || '').trim().toLowerCase();\n  if (!url) continue;\n  if (seen.has(url)) continue;\n  seen.add(url);\n  out.push(item);\n}\n\nreturn out;"
      },
