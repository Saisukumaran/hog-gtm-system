      "name": "Hog - Scrape Comments",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        400,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const out = [];\nconst src = $('Set Posts + Signal').first().json.postUrls[0];\nfor (const item of $input.all()) {\n  const comments = item.json.data || [];\n  for (const c of comments) {\n    if (c.actor) out.push({ json: { actor: c.actor, sourcePost: src } });\n    for (const r of (c.replies || [])) {\n      if (r.actor) out.push({ json: { actor: r.actor, sourcePost: src } });\n    }\n  }\n}\nreturn out;"
      },
